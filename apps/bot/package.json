{
	"name": "bot",
	"private": true,
	"version": "4.0.0",
	"description": "the bot for all things ELA",
	"main": "dist/index.js",
	"type": "module",
	"imports": {
		"#util/*": "./dist/util/*",
		"#mw/*": "./dist/util/mw/*",
		"#mw": "./dist/util/mw/index.js",
		"#util/types": "./dist/util/types/index.js",
		"#constants": "./dist/util/constants.js",
		"#logger": "./dist/util/logger.js",
		"#structures": "./dist/structures/index.js"
	},
	"scripts": {
		"generate": "node ./dist/scripts/generate.js",
		"build": "bun run copy-locales",
		"start": "node .",
		"dev": "bun run --watch src/index.ts",
		"copy-locales": "cp -r ../../packages/locales ./src && rm -f ./src/locales/package.json",
		"lint": "biome check --fix",
		"format": "biome format --write"
	},
	"author": "Carter Himmel <me@fyko.net>",
	"license": "MIT",
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.66",
		"@discordjs/builders": "^1.14.1",
		"@discordjs/rest": "^2.6.1",
		"@skyra/i18next-backend": "^2.0.5",
		"@thoth/interactions": "workspace:^",
		"@tinyhttp/app": "^3.0.6",
		"@yuudachi/framework": "0.3.6",
		"ai": "^6.0.146",
		"bullmq": "^5.73.0",
		"common-tags": "^1.8.2",
		"discord-api-types": "^0.38.44",
		"discord.js": "^14.26.2",
		"fs-nextra": "^0.5.1",
		"i18next": "^26.0.3",
		"ioredis": "^5.3.2",
		"locales": "workspace:^",
		"pino": "^8.19.0",
		"pino-pretty": "^10.3.1",
		"postgres": "^3.4.8",
		"prom-client": "^15.1.3",
		"readdirp": "^5.0.0",
		"reflect-metadata": "^0.2.2",
		"rss-parser": "^3.13.0",
		"tsyringe": "^4.10.0",
		"undici": "^8.0.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/common-tags": "^1.8.4",
		"cpy-cli": "^7.0.0",
		"dotenv": "^17.4.0",
		"mw-collegiate": "^1.0.1",
		"rimraf": "^6.1.3",
		"tsc-watch": "^7.2.0",
		"tsconfig": "workspace:^",
		"typescript": "^6.0.2"
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-angular"
		],
		"rules": {
			"type-enum": [
				2,
				"always",
				[
					"chore",
					"build",
					"ci",
					"docs",
					"feat",
					"fix",
					"perf",
					"refactor",
					"revert",
					"style",
					"test",
					"types",
					"wip"
				]
			]
		}
	},
	"volta": {
		"node": "22.22.2",
		"pnpm": "8.10.2"
	},
	"packageManager": "pnpm@8.10.2"
}
