{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": ["bun.lock", "**/tsconfig.json", "**/tsup.config.ts"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["src/**/*.ts"],
			"outputs": ["dist/**"],
			"cache": true,
			"outputLogs": "errors-only"
		},
		"dev": {
			"persistent": true
		},
		"lint": {
			"inputs": [
				"biome.json",
				"src/**/*.tsx",
				"src/**/*.ts",
				"src/**/*.css",
				"src/**/*.mdx"
			],
			"dependsOn": ["^build"],
			"outputLogs": "errors-only"
		},
		"format": {
			"inputs": [
				"biome.json",
				"src/**/*.tsx",
				"src/**/*.ts",
				"src/**/*.css",
				"src/**/*.mdx"
			],
			"dependsOn": ["^build"],
			"outputLogs": "errors-only"
		}
	}
}
