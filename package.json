{
	"name": "thoth",
	"private": true,
	"version": "0.0.0",
	"description": "the bot for all things ELA",
	"type": "module",
	"workspaces": [
		"apps/**",
		"packages/**",
		"!**/dist"
	],
	"scripts": {
		"build": "turbo run build --cache-dir=.turbo",
		"build:affected": "turbo run build --filter='...[origin/main]' --concurrency=4",
		"dev:bot": "turbo run dev --filter bot --cache-dir=.turbo",
		"dev:web": "turbo run dev --filter web --cache-dir=.turbo",
		"lint": "turbo run lint --concurrency=4 --cache-dir=.turbo",
		"format": "turbo run format --concurrency=4 --cache-dir=.turbo"
	},
	"author": "Carter Himmel <me@fyko.net>",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-angular": "^20.5.0",
		"@types/common-tags": "^1.8.4",
		"@types/node": "^20.11.27",
		"cpy-cli": "^7.0.0",
		"dotenv": "^17.4.0",
		"is-ci": "^4.1.0",
		"lint-staged": "^16.4.0",
		"rimraf": "^6.1.3",
		"ts-node": "^10.9.2",
		"turbo": "^2.9.3",
		"typescript": "^6.0.2"
	},
	"lint-staged": {
		"*": "biome format --write --no-errors-on-unmatched --files-ignore-unknown=true",
		"{src/**,__tests__/**}.{mjs,js,cjs,ts,tsx}": "biome format --write --no-errors-on-unmatched --files-ignore-unknown=true"
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-angular"
		],
		"rules": {
			"type-enum": [
				2,
				"always",
				[
					"chore",
					"build",
					"ci",
					"docs",
					"feat",
					"fix",
					"perf",
					"refactor",
					"revert",
					"style",
					"test",
					"types",
					"wip"
				]
			]
		}
	},
	"overrides": {
		"discord-api-types": "^0.38.44"
	},
	"packageManager": "bun@1.3.11"
}
